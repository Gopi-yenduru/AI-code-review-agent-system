# =============================================================================
# AI Code Review Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Google Gemini API ---
# Get your key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- GitHub Integration ---
# Webhook secret: create a random string for HMAC verification
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
# Personal Access Token: https://github.com/settings/tokens (needs repo scope)
GITHUB_TOKEN=your_github_token_here

# --- PostgreSQL Database ---
DATABASE_URL=postgresql+asyncpg://codereview:codereview@db:5432/codereview

# --- Application Settings ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
API_PREFIX=/api/v1
APP_ENV=development
LOG_LEVEL=info
